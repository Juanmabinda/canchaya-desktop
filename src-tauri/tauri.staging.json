{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CanchaYa POS (Staging)",
  "identifier": "app.canchalibre.desktop.staging",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CanchaYa POS (Staging)",
        "url": "https://staging.canchaya.ar/admin",
        "userAgent": "Mozilla/5.0 (CanchaYaPOS-Desktop-Staging/0.1.0) Tauri/2",
        "devtools": true
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Juanmabinda/canchaya-desktop/releases/latest/download/latest-staging.json"
      ]
    },
    "deep-link": {
      "desktop": {
        "schemes": ["canchaya-staging"]
      }
    }
  }
}
